{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ESNext", "dom"],
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"baseUrl": ".",
		"paths": {
			"@bug-on/md3-react": ["./packages/react/src"],
			"@bug-on/md3-tokens": ["./packages/tokens/src"]
		}
	},
	"include": ["packages/**/*.ts", "packages/**/*.tsx", "apps/**/*.ts", "apps/**/*.tsx"],
	"exclude": ["node_modules", "dist", ".next"]
}
