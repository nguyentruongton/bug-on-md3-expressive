{
	"name": "@bug-on/md3-react",
	"version": "3.0.1",
	"description": "Material Design 3 Expressive React components",
	"author": "Bug Ổn",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/nguyentruongton/bug-on-md3-expressive.git",
		"directory": "packages/react"
	},
	"keywords": [
		"react",
		"tailwind",
		"material-design-3",
		"md3",
		"ui-library",
		"components",
		"bug-on"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./typography.css": {
			"types": "./dist/typography.css.d.ts",
			"default": "./dist/typography.css"
		},
		"./index.css": {
			"types": "./dist/index.css.d.ts",
			"default": "./dist/index.css"
		},
		"./material-symbols-cdn.css": {
			"types": "./dist/material-symbols-cdn.css.d.ts",
			"default": "./dist/material-symbols-cdn.css"
		},
		"./material-symbols-self-hosted.css": {
			"types": "./dist/material-symbols-self-hosted.css.d.ts",
			"default": "./dist/material-symbols-self-hosted.css"
		},
		"./plugin": {
			"types": "./dist/plugin.d.ts",
			"import": "./dist/plugin.mjs",
			"require": "./dist/plugin.js"
		}
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"motion": ">=12.0.0"
	},
	"peerDependenciesMeta": {
		"motion": {
			"optional": true
		}
	},
	"dependencies": {
		"@bug-on/md3-tokens": "workspace:*",
		"@bug-on/md3-tailwind": "workspace:*",
		"@material/material-color-utilities": "^0.3.0",
		"@radix-ui/react-context-menu": "^2.2.16",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-slot": "^1.2.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.3.1"
	},
	"devDependencies": {
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "4.1.4",
		"jsdom": "^29.0.0",
		"tsup": "^8.4.0",
		"typescript": "5.8.3",
		"vitest": "^4.1.0"
	}
}
