{
	"name": "@bug-on/md3-react",
	"version": "0.1.0",
	"description": "Material Design 3 Expressive React components",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./typography.css": "./dist/typography.css",
		"./index.css": "./dist/index.css",
		"./material-symbols-cdn.css": "./dist/material-symbols-cdn.css",
		"./material-symbols-self-hosted.css": "./dist/material-symbols-self-hosted.css"
	},
	"files": [
		"dist",
		"README.md"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup && tsc -p tsconfig.build.json",
		"dev": "tsup --watch",
		"test": "vitest run",
		"lint": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"peerDependencies": {
		"motion": ">=12.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"peerDependenciesMeta": {
		"motion": {
			"optional": true
		}
	},
	"dependencies": {
		"@bug-on/md3-tokens": "workspace:*",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-slot": "^1.2.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.3.1"
	},
	"devDependencies": {
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^6.0.1",
		"jsdom": "^29.0.0",
		"tsup": "^8.4.0",
		"typescript": "5.8.3",
		"vitest": "^4.1.0"
	}
}
