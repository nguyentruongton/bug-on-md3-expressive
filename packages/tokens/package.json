{
	"name": "@bug-on/md3-tokens",
	"version": "3.0.0",
	"description": "Material Design 3 Expressive design tokens",
	"author": "Bug Ổn",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/nguyentruongton/bug-on-md3-expressive.git",
		"directory": "packages/tokens"
	},
	"keywords": [
		"react",
		"tailwind",
		"material-design-3",
		"md3",
		"ui-library",
		"components",
		"bug-on"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./colors.css": {
			"types": "./dist/colors.css.d.ts",
			"default": "./dist/colors.css"
		},
		"./shape.css": {
			"types": "./dist/shape.css.d.ts",
			"default": "./dist/shape.css"
		}
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist"
	},
	"devDependencies": {
		"tsup": "^8.4.0",
		"typescript": "5.8.3"
	}
}
